### State Inspector

```javascript
class StateInspector {
  static inspect(obj, label = 'State') {
    console.group(label);
    for (const [key, value] of Object.entries(obj)) {
      if (typeof value === 'object') {
        this.inspect(value, key);
      } else {
        console.log(`${key}:`, value);
      }
    }
    console.groupEnd();
  }
}

// Usage
StateInspector.inspect(gameState, 'Game State');
```

