## Workflow Automation

### Pre-Commit Checks

```bash
#!/bin/bash
# .git/hooks/pre-commit

echo "Running pre-commit checks..."

# Check file sizes
echo "Checking file sizes..."
find src -name "*.js" | while read file; do
  lines=$(wc -l < "$file")
  if [ $lines -gt 400 ]; then
    echo "❌ ERROR: $file has $lines lines (limit: 400)"
    exit 1
  elif [ $lines -gt 300 ]; then
    echo "⚠️  WARNING: $file has $lines lines (approaching limit)"
  fi
done

# Check for console.logs in production code
echo "Checking for debug statements..."
if grep -r "console.log" src/ --exclude-dir=debug; then
  echo "⚠️  WARNING: Found console.log statements"
fi

echo "✅ Pre-commit checks passed"
```

### Architecture Validator

```javascript
// Validate architecture rules
class ArchitectureValidator {
  static validate() {
    const issues = [];
    
    // Check file sizes
    const largeFiles = this.findLargeFiles('./src', 400);
    if (largeFiles.length > 0) {
      issues.push(`Files exceeding 400 lines: ${largeFiles.join(', ')}`);
    }
    
    // Check for direct system dependencies
    const coupledFiles = this.findDirectDependencies();
    if (coupledFiles.length > 0) {
      issues.push(`Files with direct system dependencies: ${coupledFiles.join(', ')}`);
    }
    
    // Check for magic numbers
    const magicNumbers = this.findMagicNumbers();
    if (magicNumbers.length > 10) {
      issues.push(`Found ${magicNumbers.length} magic numbers`);
    }
    
    return issues;
  }
}
```

