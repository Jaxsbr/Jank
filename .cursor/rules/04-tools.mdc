## Architecture Documentation Tools

### Auto-Generate Component List

```javascript
// Script to list all components
const fs = require('fs');
const path = require('path');

function scanDirectory(dir, prefix = '') {
  const items = fs.readdirSync(dir);
  const components = [];
  
  for (const item of items) {
    const fullPath = path.join(dir, item);
    const stat = fs.statSync(fullPath);
    
    if (stat.isDirectory()) {
      components.push(...scanDirectory(fullPath, prefix + item + '/'));
    } else if (item.endsWith('.js')) {
      const lines = fs.readFileSync(fullPath, 'utf8').split('\n').length;
      components.push({
        name: item,
        path: prefix + item,
        lines: lines
      });
    }
  }
  
  return components;
}

// Run and generate report
const components = scanDirectory('./src');
console.table(components.sort((a, b) => b.lines - a.lines));
```

